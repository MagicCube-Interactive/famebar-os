# ============================================================================
# SUPABASE CLIENT CONFIGURATION (Public - Safe to Expose)
# ============================================================================
# Get these values from Supabase Console > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://kwfheipopereldimajbb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================================
# SUPABASE ADMIN SDK CONFIGURATION (Secret - Never Expose)
# ============================================================================
# Get this from Supabase Console > Settings > API > Service Role Key
# WARNING: This contains sensitive credentials. Keep it in .env.local and never commit to git

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

NEXT_PUBLIC_APP_NAME=FameBar OS
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 1. Copy this file: cp .env.example .env.local
#
# 2. Get Supabase credentials:
#    a. Go to Supabase Console (https://app.supabase.com)
#    b. Select your project (kwfheipopereldimajbb)
#    c. Go to Settings > API
#    d. Copy NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
#    e. Copy Service Role Key and paste as SUPABASE_SERVICE_ROLE_KEY
#
# 3. Never commit .env.local to version control
#    - Add to .gitignore (already there)
#
# 4. Set up the database schema:
#    a. Go to Supabase Console > SQL Editor
#    b. Paste the contents of supabase/schema.sql
#    c. Click "Run"
#
# 5. Test by running: npm run dev
#    - Go to http://localhost:3000/login
#    - Try creating an account at http://localhost:3000/register
